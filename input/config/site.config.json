            "afterPost": "",
            "afterPage": "<!-- Karussel Links - Carousel links -->\n<script type=\"text/javascript\" defer>\n//<![CDATA[\n\tvar carousel_imgs = null;\n\ttry {\n  \tcarousel_imgs = Array.from(document.getElementById(\"scrollable\").children).map(x => x.children[0]);\n\t} catch (e) {}\n\t\n\tif (carousel_imgs != null) {//there is a carousel on this site\n  \tcarousel_imgs.forEach((imgs, index) => {\n\t\t\timgs.setAttribute(\"srcset\", imgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-480.JPG 480w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-768.JPG 768w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-1024.JPG 1024w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-1440.JPG 1440w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-1920.JPG 1920w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-2560.JPG 2560w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-3840.JPG 3840w, \"+\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\timgs.getAttribute(\"src\").split(\"-1024.JPG\")[0]+\"-8192.JPG 8192w\");\n\t\t\timgs.src = imgs.src; //reloads the image with srcset\n\t\t});\n\t}\n//]]>\n</script>\n\n<!-- Kontaktformular - Contact Form -->\n<script type=\"text/javascript\">\n//<![CDATA[\n\tfunction autoResizeTextarea(event){\n\t\tconst elem = event.target;\n\t\telem.style.height = \"auto\";\n  \tif(elem.scrollHeight > 140){\n\t\t\t\telem.style.setProperty(\"height\", (elem.scrollHeight+22) + \"px\", \"important\");\n    }\n\t}\n\tfunction countChars(event){\n\t\tconst maxLength = event.target.getAttribute(\"maxlength\");\n  \tconst currentLength = event.target.value.length;\n\t\tdocument.getElementById(\"char-counter\").innerHTML = currentLength+\"/\"+maxLength;\n\t}\n\tfor(i = 0; i < document.getElementsByClassName(\"contact-inputs\").length; i++){\n    var elem = document.getElementsByClassName(\"contact-inputs\")[i];\n\t\tif(elem.tagName.toLowerCase() == \"textarea\"){\n\t\t\telem.addEventListener(\"input\", autoResizeTextarea);\n\t\t\telem.addEventListener(\"input\", countChars);\n\t\t}\n\t}\n//]]>\n</script>\n\n<script type=\"text/javascript\" defer>\n//<![CDATA[\n\t/*if(document.getElementById(\"SubmitButtonInContactForm\") != null && document.getElementById(\"char-counter\") != null)*/ \ntry{\n\t\tdocument.getElementById(\"SubmitButtonInContactForm\").innerHTML = document.getElementById(\"SubmitButtonInContactForm\").innerHTML+\" <ion-icon name='arrow-forward-outline'></ion-icon>\";\n\t\tdocument.getElementById(\"char-counter\").innerHTML = \"0/\"+Array.from(document.getElementsByClassName(\"contact-inputs\")).filter(x => x.tagName.toLowerCase() == \"textarea\")[0].getAttribute(\"maxlength\");\n\n\nsubjectinput.onfocus = function () {\n  subject.style.display = 'block';\n};\n\nwindow.addEventListener(\"mousedown\", function(event) {\n\tif (event.target != subjectinput && event.target != subject && !Array.from(subject.children).includes(event.target)) {\n  \tsubject.style.display = \"none\";\n\t}\n});\n\nfor (let option of subject.options) {\n  option.addEventListener(\"click\", function () {\n\t\tif(option.value == \"emptySpace\"){\n\t\t\tsubjectinput.value = \"\";\n\t\t}else{\n    \tsubjectinput.value = option.value;\n    }\n\t\tsubject.style.display = 'none';\n\t\toption.classList.remove(\"active\");\n  });\n};\n\nsubjectinput.oninput = function() {\n  currentFocus = -1;\n  var text = subjectinput.value.toUpperCase();\n  for (let option of subject.options) {\n    if(option.value.toUpperCase().indexOf(text) > -1){\n      option.style.display = \"block\";\n  \t}else if(option.value == \"emptySpace\"){\n\t\t\toption.style.display = \"block\";\n\t\t}else{\n    \toption.style.display = \"none\";\n    }\n  };\n}\nvar currentFocus = -1;\nsubjectinput.onkeydown = function(e) {\n  if(e.keyCode == 40){ /* \"Arrow-Down\"-Key */\n  \tcurrentFocus++;\n  \taddActive(subject.options);\n  }\n  else if(e.keyCode == 38){ /* \"Arrow-Up\"-Key */\n  \tcurrentFocus--;\n  \taddActive(subject.options);\n  }\n  else if(e.keyCode == 13){ /* \"Enter\"-Key */\n    if (currentFocus > -1) {\n    \te.preventDefault();\n    \t/*and simulate a click on the \"active\" item:*/\n    \tif (subject.options) {\n\t\t\t\tsubject.options[currentFocus].click();\n\t\t\t}\n    }else {\n\t\t\tsubject.style.display = 'none';\n\t\t}\n  }else if(e.keyCode == 9){ /* \"Tab\"-Key */\n\t\tsubject.style.display = 'none';\n\t}\n}\n\n\t}catch(e){}\n\nfunction addActive(x) {\n    if (!x) return false;\n    removeActive(x);\n    if (currentFocus >= x.length) currentFocus = 0;\n    if (currentFocus < 0) currentFocus = (x.length - 1);\n    x[currentFocus].classList.add(\"active\");\n  }\n  function removeActive(x) {\n    for (var i = 0; i < x.length; i++) {\n      x[i].classList.remove(\"active\");\n    }\n  }\n//]]>\n</script>\n\n<script type=\"text/javascript\" defer>\n//<![CDATA[\n\ttry{\n\t\tdocument.getElementById(\"form_name\").value;\n\t\ttry{\n\t\t\tlet nodemailer = require('nodemailer');\n\t\t\tsendMail();\n\t\t}\n\t\tcatch(e){\n\t\t\tconsole.log(\"Nodemailer could not be loaded\");\n\t\t\t//document.getElementsByClassName(\"contact-container\")[0].setHTMLUnsafe(\"<div class='contact-container-error'><p>Kontaktformular konnte nicht geladen werden</p><p>Contactform could not be loaded</p></div>\");\n\t\t\t//.contact-container-error, .contact-container-error p {\n    \t//\ttext-align: center;\n    \t//\tfont-size: 30px;\n    \t//\tmargin: 0;\n\t\t\t//}\n\t\t}\n\t}\n\tcatch(e){}\n\tfunction sendMail(name, email, subject, message){\n\t\tlet form_name = document.getElementById(\"form_name\").value;\n\t\tlet form_email = document.getElementById(\"email\").value;\n\t\tlet form_subject = document.getElementById(\"subjectinput\").value;\n\t\tlet form_message = document.getElementById(\"message\").value;\n\t\t\n\t\tlet transporter = nodemailer.createTransport({\n  \t\tservice: 'gmail',\n  \t\tauth: {\n  \t\t  user: 'youremail@gmail.com',\n  \t\t  pass: 'yourpassword'\n  \t\t}\n\t\t});\n\n\t\tlet mailOptions = {\n\t\t  from: form_email,\n\t\t  to: 'myfriend@yahoo.com',\n\t\t  subject: 'Sending Email using Node.js',\n\t\t  text: form_message\n\t\t};\n\t\t\n\t\ttransporter.sendMail(mailOptions, function(error, info){\n\t\t  if (error) {\n\t\t    console.log(error);\n\t\t  } else {\n\t\t    console.log('Email sent: ' + info.response);\n\t\t  }\n\t\t});\n\t}\t\n//]]>\n</script>\n\n<!-- Slideshow - Carousel -->\n<script type=\"text/javascript\" defer>\n//<![CDATA[\n\ttry{\n\t\n\tsetInterval(() => scrollSlide(1), 15000);\n\t\n  let prev = document.getElementById(\"prev-button\");\n\tlet next = document.getElementById(\"next-button\");\n\tprev.addEventListener(\"click\", () => scrollSlide(-1));\n  next.addEventListener(\"click\", () => scrollSlide(1));\n  prev.addEventListener(\"mouseleave\", () => prev.blur());\n  next.addEventListener(\"mouseleave\", () => next.blur());\n\t\n\tdocument.getElementById(\"scrollable\").addEventListener(\"mouseover\", () => prev.style.setProperty(\"visibility\", \"visible\"));\n\tdocument.getElementById(\"scrollable\").addEventListener(\"mouseover\", () => next.style.setProperty(\"visibility\", \"visible\"));\n\tdocument.getElementById(\"scrollable\").addEventListener(\"mouseout\", () => prev.style.setProperty(\"visibility\", \"hidden\"));\n\tdocument.getElementById(\"scrollable\").addEventListener(\"mouseout\", () => next.style.setProperty(\"visibility\", \"hidden\"));\n\t\n\tdocument.getElementById(\"prev-button\").addEventListener(\"mouseover\", () => prev.style.setProperty(\"visibility\", \"visible\"));\n\tdocument.getElementById(\"prev-button\").addEventListener(\"mouseover\", () => next.style.setProperty(\"visibility\", \"visible\"));\n\tdocument.getElementById(\"prev-button\").addEventListener(\"mouseout\", () => prev.style.setProperty(\"visibility\", \"hidden\"));\n\tdocument.getElementById(\"prev-button\").addEventListener(\"mouseout\", () => next.style.setProperty(\"visibility\", \"hidden\"));\n\t\n\tdocument.getElementById(\"next-button\").addEventListener(\"mouseover\", () => prev.style.setProperty(\"visibility\", \"visible\"));\n\tdocument.getElementById(\"next-button\").addEventListener(\"mouseover\", () => next.style.setProperty(\"visibility\", \"visible\"));\n\tdocument.getElementById(\"next-button\").addEventListener(\"mouseout\", () => prev.style.setProperty(\"visibility\", \"hidden\"));\n\tdocument.getElementById(\"next-button\").addEventListener(\"mouseout\", () => next.style.setProperty(\"visibility\", \"hidden\"));\n\t}catch(e){}\n\t\n\tfunction scrollSlide(direction){\n\t\ttry{\n\t\tif(document.getElementById(\"scrollable\").scrollLeft + document.getElementById(\"scrollable\").lastChild.clientWidth + 10 >= document.getElementById(\"scrollable\").scrollWidth && direction==1) {\n\t\t\tdocument.getElementById(\"scrollable\").scrollTo({\n                    top: 0,\n                    left: 0,\n                    behavior: \"smooth\"\n                });\n\t\t\treturn;\n\t\t}\n\t\tif(document.getElementById(\"scrollable\").scrollLeft == 0 && direction == -1) {\n\t\t\tdocument.getElementById(\"scrollable\").scrollBy({\n                    top: 0,\n                    left: (document.getElementById(\"scrollable\").childElementCount-1)*(document.getElementById(\"scrollable\").clientWidth)+1,\n                    behavior: \"smooth\"\n                });\n\t\t\treturn;\n\t\t}\n  \tdocument.getElementById(\"scrollable\").scrollBy({\n                    top: 0,\n                    left: direction*(document.getElementById(\"scrollable\").clientWidth),\n                    behavior: \"smooth\"\n                });\n\t}catch(e){}\n  }\n\t\n//]]>\n</script>\n\n<!-- Email Obfuscation -->\n<script type=\"text/javascript\" defer>\n//<![CDATA[\n\t/* Mailaddress obfuscation */\n\tArray.from(document.getElementsByTagName(\"a\")).filter(x => x.getAttribute(\"href\").startsWith(\"mailto:\")).forEach(x => x.setAttribute(\"href\", \"mailto:\"+atob(x.getAttribute(\"href\").split(\"mailto:\")[1])));\n\tArray.from(document.getElementsByTagName(\"a\")).filter(x => x.getAttribute(\"href\").startsWith(\"mailto:\")).forEach(x => x.innerHTML = x.innerHTML.replace(btoa(x.getAttribute(\"href\").split(\"mailto:\")[1]), x.getAttribute(\"href\").split(\"mailto:\")[1]));\n\t/* Telephonenumber obfuscation */\n\tArray.from(document.getElementsByTagName(\"a\")).filter(x => x.getAttribute(\"href\").startsWith(\"tel:\")).forEach(x => x.setAttribute(\"href\", \"tel:\"+atob(x.getAttribute(\"href\").split(\"tel:\")[1])));\n\tArray.from(document.getElementsByTagName(\"a\")).filter(x => x.getAttribute(\"href\").startsWith(\"tel:\")).forEach(x => x.innerHTML = x.innerHTML.replace(btoa(x.getAttribute(\"href\").split(\"tel:\")[1]), x.getAttribute(\"href\").split(\"tel:\")[1]));\n//]]>\n</script>"
        }
